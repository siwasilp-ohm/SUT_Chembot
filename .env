# ============================================================================
# ChemInventory AI - Environment Configuration
# For: https://ohm044.xyz/v1 on VPS with XAMPP
# ============================================================================

# ════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_NAME=chem_inventory_db
DB_USER=root
DB_PASS=

# ════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ════════════════════════════════════════════════════════════
APP_NAME=SUT chemBot
APP_ENV=production
APP_URL=https://ohm044.xyz/v1
APP_TIMEZONE=Asia/Bangkok

# ════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ════════════════════════════════════════════════════════════
# Generate secure JWT secret with: php -r 'echo bin2hex(random_bytes(32));'
JWT_SECRET=your-very-secure-random-key-change-this-in-production

# ════════════════════════════════════════════════════════════
# AI & API CONFIGURATION (Optional)
# ════════════════════════════════════════════════════════════
# AI_API_KEY=your-openai-api-key
# AI_API_ENDPOINT=https://api.openai.com/v1
# VISION_API_KEY=your-google-vision-api-key

# ════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Optional)
# ════════════════════════════════════════════════════════════
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@cheminventory.local

# ════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ════════════════════════════════════════════════════════════
ENABLE_AR_FEATURES=true
ENABLE_AI_FEATURES=true
ENABLE_VISUAL_SEARCH=false
