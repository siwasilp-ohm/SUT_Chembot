# ============================================================================
# .htaccess Configuration for ChemInventory AI (SUT chemBot)
# Adapted from HICM-V2025 stable pattern
# Domain: https://ohm044.xyz/v1
# HTTPS is handled by Apache VirtualHost config, not here
# ============================================================================

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /v1/
    
    # ════════════════════════════════════════════════════════════
    # SECURITY - Block sensitive files & directories
    # ════════════════════════════════════════════════════════════
    
    # Block direct access to sensitive files
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^\.env\.example$ - [F,L]
    RewriteRule ^\.htaccess$ - [F,L]
    RewriteRule ^\.git/ - [F,L]
    RewriteRule ^composer\.json$ - [F,L]
    RewriteRule ^composer\.lock$ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^\.gitignore$ - [F,L]
    
    # Block debug and backup files
    RewriteRule ^debug_.*\.php$ - [F,L]
    RewriteRule ^test_.*\.php$ - [F,L]
    RewriteRule ^.*_backup\.php$ - [F,L]
    RewriteRule ^.*\.bak$ - [F,L]
    
    # Skip if it's a real directory or file
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -l
    RewriteRule ^ - [L]
    
    # Route non-existent requests to index.php
    RewriteRule ^(.*)$ index.php?q=$1 [QSA,L]
</IfModule>

# ════════════════════════════════════════════════════════════
# DISABLE DIRECTORY LISTING
# ════════════════════════════════════════════════════════════
Options -Indexes

# ════════════════════════════════════════════════════════════
# CHARACTER ENCODING
# ════════════════════════════════════════════════════════════
AddDefaultCharset utf-8
AddCharset UTF-8 .html .css .js .json .php .xml

# ════════════════════════════════════════════════════════════
# DENY ACCESS TO SENSITIVE FILE TYPES
# ════════════════════════════════════════════════════════════
<FilesMatch "\.(env|env\.example|sql|txt|md|bak|log|tmp|ini|cfg|conf|yml|yaml)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ════════════════════════════════════════════════════════════
# COMPRESSION & CACHING (Performance)
# ════════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/xml application/x-javascript application/rss+xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 2 days"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/html "access plus 2 hours"
</IfModule>

<IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable"
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.php$">
        Header set Cache-Control "private, no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>
